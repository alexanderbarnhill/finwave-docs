{
  "navigationFallback": {
    "rewrite": "/404.html",
    "exclude": ["/_astro/*", "/pagefind/*", "*.css", "*.js", "*.svg", "*.png", "*.jpg", "*.ico"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html"
    }
  },
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".webmanifest": "application/manifest+json"
  }
}
